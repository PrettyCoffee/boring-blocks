{
  "name": "boring-blocks",
  "version": "0.0.0",
  "description": "Boring react components for classic shadcn style productivity UIs",
  "author": "PrettyCoffee",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "scripts",
    "tsconfig.json",
    "tsconfig.*.json",
    "vite.config.ts",
    "*.md"
  ],
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/index-utils.d.ts",
      "import": "./dist/index-utils.mjs"
    },
    "./icons": {
      "types": "./dist/index-icons.d.ts",
      "import": "./dist/index-icons.mjs"
    },
    "./tailwind": {
      "import": "./tailwind/index.ts"
    }
  },
  "bin": {
    "boring-blocks": "./scripts/cli.mjs"
  },
  "scripts": {
    "start": "pnpm run --filter ./docs start",
    "build": "node ./scripts/build.mjs",
    "build:docs": "pnpm run --filter ./docs build",
    "lint": "tsc -b && eslint",
    "lint:fix": "pnpm run lint --fix",
    "postinstall": "node ./scripts/cli.mjs build"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.3.0",
    "@floating-ui/react": "^0.27.19",
    "@floating-ui/react-dom": "^2.1.8",
    "@yaasl/react": "^0.15.0-alpha.1",
    "goober": "^2.1.18",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@base-ui/react": "1.4.0",
    "@floating-ui/react": "0.27.19",
    "@floating-ui/react-dom": "2.1.8",
    "@pretty-cozy/eslint-config": "0.9.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@yaasl/react": "0.15.0-alpha.1",
    "eslint": "9.39.4",
    "eslint-plugin-storybook": "10.3.5",
    "goober": "2.1.18",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
