{
  "name": "boring-blocks",
  "version": "0.0.0",
  "description": "Boring react components for classic shadcn style productivity UIs",
  "author": "PrettyCoffee",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "scripts",
    "tsconfig.json",
    "tsconfig.*.json",
    "vite.config.ts",
    "*.md"
  ],
  "module": "dist/index.mjs",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.mjs"
  },
  "bin": {
    "boring-blocks": "./scripts/cli.mjs"
  },
  "scripts": {
    "start": "pnpm run --filter ./docs start",
    "build": "node ./scripts/build.mjs",
    "build:docs": "pnpm run --filter ./docs build",
    "lint": "tsc -b && eslint",
    "lint:fix": "pnpm run lint --fix",
    "postinstall": "node ./scripts/cli.mjs build"
  },
  "peerDependencies": {
    "@yaasl/react": "^0.15.0-alpha.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@pretty-cozy/eslint-config": "0.8.0",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@yaasl/react": "0.15.0-alpha.1",
    "eslint": "9.39.4",
    "eslint-plugin-storybook": "10.2.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
